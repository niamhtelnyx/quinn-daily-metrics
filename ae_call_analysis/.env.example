# V1 Call Intelligence Configuration
# Copy this file to .env and configure your API keys

# Fellow API Configuration (Required)
FELLOW_API_KEY=your_fellow_api_key_here

# Optional: Slack webhook for direct posting
# Get this from Slack App settings -> Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Salesforce integration (ready for V2)
# SF_CLIENT_ID=your_salesforce_client_id
# SF_CLIENT_SECRET=your_salesforce_client_secret
# SF_DOMAIN=your_salesforce_domain

# Optional: Enhanced AI analysis (ready for V2)
# OPENAI_API_KEY=sk-proj-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-claude-key

# Database Configuration (auto-configured)
DATABASE_PATH=v1_production.db